<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.account.LoginFragment">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradiente_green"
        android:scaleType="fitXY"
        android:src="@drawable/img_login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:gravity="center"
        android:background="@drawable/bg_text_view"
        android:orientation="vertical"
        android:padding="5dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/imageView">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/ic_car_green_24"
            android:drawablePadding="5dp"
            android:gravity="center"
            android:layout_marginHorizontal="10dp"
            android:text="MoviNível"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linlay_boas_vindas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/divider"
        android:elevation="10dp"
        app:layout_constraintEnd_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/divider"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bienvenido a\n MoviNível"
            android:textSize="38sp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imageView"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#A0B3A9"
            android:text="Inicia sesión para comenzar a ganar\nreembolsos en tus viajes."
            app:layout_constraintTop_toBottomOf="@id/txt_title"/>


    </LinearLayout>

    <FrameLayout
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:background="@drawable/bg_gradiente_green"
        android:elevation="5dp"
        android:translationY="-10dp"
        app:layout_constraintTop_toBottomOf="@id/imageView"
        tools:layout_editor_absoluteX="0dp" />

    <LinearLayout
        android:id="@+id/linlay_accont"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/linlay_boas_vindas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo electrónico"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Escribe aquí"
                android:textColorHint="#9DB8A8"
                android:background="@drawable/bg_edit_text_fundo_primary"
                android:layout_marginTop="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textStyle="bold"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Escribe aquí"
                android:drawableEnd="@drawable/ic_eyes_24"
                android:textColorHint="#9DB8A8"
                android:background="@drawable/bg_edit_text_fundo_primary"
                android:layout_marginTop="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Olvidé mi contraseña"
                android:gravity="end"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textColor="#9DB8A8"
                android:layout_marginEnd="10dp"/>
            
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_Entrar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_buttom_gren_terty"
                android:layout_marginTop="40dp"
                android:text="CUENTA DE ACCESO"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/primary"/>


        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="@id/linlay_accont"
        app:layout_constraintStart_toStartOf="@id/linlay_accont"
        app:layout_constraintEnd_toEndOf="@id/linlay_accont">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="¿Nuevo aquí?"
            android:textSize="16sp"
            android:textColor="#A0B3A9"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="Registro"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/Third"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>