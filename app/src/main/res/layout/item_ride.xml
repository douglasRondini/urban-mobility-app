<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginVertical="5dp"
    android:background="@drawable/bg_card_raio_48"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="21dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgPerfil"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/img_login"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Button"
                android:scaleType="fitXY"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="11dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ana Silva"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" UberX"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 24,90"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text=" 14:31"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"/>
                
            </LinearLayout>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="21dp"
            android:orientation="horizontal">
            <View
                android:layout_width="1dp"
                android:layout_height="42dp"
                android:layout_marginStart="5dp"
                android:layout_gravity="center"
                android:background="@color/white"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Av. Paulista, 1000 - Bela Vista"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:drawableLeft="@drawable/ic_point"
                    android:drawablePadding="5dp"/>
                <View
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R. Augusta, 500 - Consolação"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:drawableLeft="@drawable/ic_point"
                    android:drawableTint="@color/Third"
                android:drawablePadding="5dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="@drawable/bg_text_view"
            android:layout_marginTop="21dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Concluída"
                android:textSize="14sp"
                android:textColor="@color/Third"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_check_circle"
                android:drawablePadding="5dp"
                android:drawableTint="@color/Third"
                android:gravity="start"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/cashback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edit_text_fundo_primary"
                android:text="+ R$ 0,50 Cashback"
                android:textColor="@color/Third"
                android:drawableLeft="@drawable/icpig"
                android:drawablePadding="5dp"/>

        </LinearLayout>



    </LinearLayout>
</LinearLayout>