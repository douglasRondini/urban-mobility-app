<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.saque.SaqueFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/ic_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_back_24"
                android:layout_gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/retirar_ganancias"
                android:gravity="center"
                android:layout_gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_help"
                android:layout_gravity="center"
                android:layout_marginEnd="10dp"/>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <LinearLayout
            android:id="@+id/linlay_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardInfoMoney"
                android:layout_width="match_parent"
                android:layout_height="123dp"
                android:layout_marginTop="21dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_edit_text_fundo_primary">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/saldo_dispon_vel_para_saque"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/txtMoney"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="R$ 1.250,00"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="36dp"
                    android:gravity="center"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="31dp"
                android:text="@string/quanto_voc_quer_sacar"
                android:textSize="14sp"
                android:textColor="#9CA3AF"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="81dp"
                android:background="@drawable/bg_edit_text_fundo_primary"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$"
                    android:layout_marginStart="21dp"
                    android:textColor="#30E87A"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/txtValueSaque"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="number"
                    android:hint="0,00"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    android:textSize="24sp"
                    android:layout_marginStart="5dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMax"
                    android:layout_width="61dp"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:text="MÁX"
                    android:layout_marginEnd="21dp"
                    android:gravity="center"
                    android:textColor="#30E87A"
                    android:paddingHorizontal="11dp"/>



            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:orientation="horizontal">


                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn50"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:elevation="5dp"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:text="R$ 50"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:paddingHorizontal="11dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn100"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:elevation="5dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:text="R$ 100"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:paddingHorizontal="11dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn200"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:elevation="5dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:text="R$ 200"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:paddingHorizontal="11dp"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn500"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    android:elevation="5dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:text="R$ 500"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:paddingHorizontal="11dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="21dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/m_todo_de_recebimento"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/icbanco"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="11dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transfer_ncia"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/at_2_dias_teis"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>

                    </LinearLayout>

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="11dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="111dp"
                    android:background="@drawable/bg_card_raio_48"
                    android:layout_marginTop="21dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="16dp"
                        android:layout_marginHorizontal="21dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/conta_de_destino"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/txtAlterarConta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alterar"
                                android:textSize="12sp"
                                android:textColor="#30E87A"
                                android:textStyle="bold"/>


                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/icbanco"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:layout_marginStart="16dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/conta_bancaria_para_ted"
                                    android:textSize="14sp"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/_456_789"
                                    android:textSize="14sp"
                                    android:textColor="#9CA3AF"/>

                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="41dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="11dp"
                        android:layout_weight="1"
                        android:text="@string/valor_total_a_receber"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:layout_marginEnd="11dp"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:elevation="5dp"
                    android:layout_marginTop="11dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_buttom_gren_terty">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/confirmar_saque"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:drawableLeft="@drawable/ic_check_circle"
                        android:drawablePadding="5dp"/>

                </LinearLayout>
            </LinearLayout>






        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>